  <co:TimeSeries rdf:ID="P09ULFRfear">
    <co:timeSeriesSource>https://road.affectivese.org/datasets/InconsistencyDataset/P09ULFRfear.csv</co:timeSeriesSource>
    <pc:hasProperty>
      <pc:Property rdf:ID="sysFR">
        <pc:hasKey>system</pc:hasKey>
        <pc:hasValue>FR</pc:hasValue>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
      </pc:Property>
    </pc:hasProperty>
    <co:hasObservableInformation>
      <co:ObservableInformation rdf:ID="obsInfP09UL">
        <co:hasRecording>
          <co:Recording rdf:ID="recP09UL">
            <co:hasRegisteredChannel>
              <co:RegisteredChannel rdf:ID="rcP09UL">
                <co:hasRegisteredData>
                  <co:RegisteredData rdf:ID="rdP09UL">
                    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
