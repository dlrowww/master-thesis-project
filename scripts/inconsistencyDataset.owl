                  <co:ActivityExecution rdf:ID="actExecP09">
                    <co:hasActivity>
                      <co:Activity rdf:ID="act">
                        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
                      </co:Activity>
                    </co:hasActivity>
                    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
                  </co:ActivityExecution>
                </co:hasActivityExecution>
                <co:hasParticipantState>
                  <co:ParticipantState rdf:ID="P09State">
                    <co:hasApperance>
                      <appearanceOcclusion:ApperanceOcclusionModel rdf:ID="P09StateAOM">
                        <appearanceOcclusion:hasMoustacheValue rdf:resource="http://www.semanticweb.org/GRISERA/contextualOntology/models/appearanceOcclusion#appearanceSome"/>
                        <appearanceOcclusion:hasBeardValue rdf:resource="http://www.semanticweb.org/GRISERA/contextualOntology/models/appearanceOcclusion#appearanceHeavy"/>
                        <appearanceOcclusion:hasGlasses rdf:datatype=
                        "http://www.w3.org/2001/XMLSchema#boolean"
                        >true</appearanceOcclusion:hasGlasses>
                        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
                      </appearanceOcclusion:ApperanceOcclusionModel>
                    </co:hasApperance>
                    <co:hasParticipant>
                      <co:Participant rdf:ID="P09">
                        <co:hasSex rdf:resource="http://www.semanticweb.org/GRISERA/contextualOntology#sexMale"/>
                        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
                      </co:Participant>
                    </co:hasParticipant>
                    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
                  </co:ParticipantState>
                </co:hasParticipantState>
                <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
              </co:Participation>
            </co:hasParticipation>
            <pc:hasProperty>
              <pc:Property rdf:ID="camLocUL">
                <pc:hasKey>cameraLocation</pc:hasKey>
                <pc:hasValue>UL</pc:hasValue>
                <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
              </pc:Property>
            </pc:hasProperty>
            <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
          </co:Recording>
        </co:hasRecording>
        <co:hasModality rdf:resource="http://www.semanticweb.org/GRISERA/contextualOntology#modalityFacialExpressions"/>
        <co:hasLifeActivity rdf:resource="http://www.semanticweb.org/GRISERA/contextualOntology#lifeActivityMovement"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
      </co:ObservableInformation>
    </co:hasObservableInformation>
    <co:hasMeasure>
      <co:Measure rdf:ID="fearMeasure">
        <co:hasMeasureName rdf:resource="http://www.semanticweb.org/GRISERA/contextualOntology/models/emotionalMeasures/ekman#fear"/>
        <co:measureDatatype>float</co:measureDatatype>
        <co:measureRange>&lt;0,1&gt;</co:measureRange>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
      </co:Measure>
    </co:hasMeasure>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
